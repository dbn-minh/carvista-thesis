NODE_ENV=development
PORT=4000
APP_PUBLIC_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
TRUST_PROXY=false
LOG_FORMAT=dev
JSON_LIMIT=2mb

# Database: prefer a single Railway/MySQL connection string in production
DATABASE_URL=mysql://user:password@localhost:3306/carvista
# Or use split variables instead
DB_HOST=localhost
DB_PORT=3306
DB_NAME=carvista
DB_USER=user
DB_PASSWORD=password
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Example: https://*.vercel.app
CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_ALLOW_CREDENTIALS=true

# Auth
JWT_SECRET=replace_me
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
OTP_SECRET=replace_me
OTP_CODE_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESENDS=3
OTP_MAX_CHALLENGES_PER_HOUR=5
SOCIAL_STATE_SECRET=replace_me

# Social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# Notifications
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Media uploads
IMAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=carvista

# Pricing / intelligence
PRICE_DROP_THRESHOLD=0.03
